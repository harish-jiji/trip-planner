rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       USERS
       ========================= */
    match /users/{userId} {

      // Logged-in users can read profiles (for friend search)
      allow read: if request.auth != null;

      // Create own profile
      allow create: if request.auth != null
                    && request.auth.uid == userId;

      // Update or delete own profile
      allow update, delete: if request.auth != null
                            && request.auth.uid == userId;
    }


    /* =========================
       TRIPS
       ========================= */
    match /trips/{tripId} {

      // Public share page
      allow read: if resource.data.isPublic == true
      || (request.auth != null
          && request.auth.uid == resource.data.ownerId)
      || (request.auth != null
          && request.auth.uid in resource.data.sharedWithFriends);

      // Create trip
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId;

      // Update or delete only by owner
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.ownerId;
    }


    /* =========================
       FRIEND REQUESTS
       ========================= */
    match /friendRequests/{requestId} {

      // Allow query reads for logged-in users
      allow read: if request.auth != null;

      // Sender creates request
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.fromUserId;

      // Receiver updates request
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.toUserId;

      // Sender or receiver can delete
      allow delete: if request.auth != null
                    && (
                        request.auth.uid == resource.data.fromUserId
                        || request.auth.uid == resource.data.toUserId
                       );
    }


    /* =========================
       FRIENDS LIST
       ========================= */
    match /friends/{friendId} {

      // Allow queries
      allow read: if request.auth != null;

      allow create: if request.auth != null;

      allow delete: if request.auth != null
                    && (
                        request.auth.uid == resource.data.userA
                        || request.auth.uid == resource.data.userB
                       );
    }


    /* =========================
       RECEIVED TRIPS
       ========================= */
    match /receivedTrips/{docId} {

      // Only receiver can read
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.toUserId;

      // Only sender can create
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.fromUserId;

      // Only receiver can delete (after cloning)
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.toUserId;
    }


    /* =========================
       DEFAULT DENY
       ========================= */
    match /{document=**} {
      allow read, write: if false;
    }

  }
}